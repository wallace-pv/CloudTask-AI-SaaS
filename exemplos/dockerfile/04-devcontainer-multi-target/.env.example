# Variáveis usadas pelos docker-compose deste exemplo.
# Copie para .env e ajuste:
#   cp .env.example .env

# ----- API -----
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-me
LOG_LEVEL=DEBUG

# ----- PostgreSQL -----
POSTGRES_USER=cloudtask
POSTGRES_PASSWORD=cloudtask
POSTGRES_DB=cloudtask

# URL de conexão para a API. Em dev usa o serviço `db` do compose.
DATABASE_URL=postgresql+psycopg2://cloudtask:cloudtask@db:5432/cloudtask
