# Variáveis usadas pelo docker-compose.yml deste exemplo.
# Copie para .env e ajuste conforme necessário:
#   cp .env.example .env

# ----- API -----
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-me

# ----- Banco PostgreSQL -----
POSTGRES_USER=cloudtask
POSTGRES_PASSWORD=cloudtask
POSTGRES_DB=cloudtask

# DATABASE_URL é montada a partir das variáveis acima.
# Note que o host é "db" (nome do serviço no docker-compose), não localhost.
DATABASE_URL=postgresql+psycopg2://cloudtask:cloudtask@db:5432/cloudtask
